# Notion-AI Configuration Template
# Copy this file to .env and fill in actual values.

# ----------------------------------------------------------
# 1. Notion Accounts
# ----------------------------------------------------------
# Core credential pool: JSON array of Notion account configurations.
# Must include: token_v2, space_id, user_id.
# Multiple accounts enable load balancing and rate-limit rotation.
# Recommended: run `python login.py` locally to create or refresh account configuration.
# ----------------------------------------------------------
NOTION_ACCOUNTS='[{"profile_name":"default","token_v2":"your_token","space_id":"your_space","user_id":"your_uid","space_view_id":"your_view","user_name":"your_name","user_email":"your_email"}]'

# ----------------------------------------------------------
# 2. FastAPI Service & Security
# ----------------------------------------------------------
# API_KEY: Bearer token required by clients calling /v1/chat/completions.
# Leave empty to disable auth. This is not recommended for production.
API_KEY=your-api-key-here

# HOST: service bind address. 0.0.0.0 allows external network access.
HOST=0.0.0.0

# PORT: internal service port.
PORT=8000

# ALLOWED_ORIGINS: comma-separated CORS origins.
# Use concrete origins in production. Avoid wildcard CORS in production.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ----------------------------------------------------------
# 3. Application Mode
# ----------------------------------------------------------
# APP_MODE: application runtime mode.
# - standard: full context, thinking/search support, no database; recommended.
# - lite: single-turn Q&A, no memory, no database.
# - heavy: full session management; requires SQLite + SILICONFLOW_API_KEY.
APP_MODE=standard

# ----------------------------------------------------------
# 4. Docker Configuration
# ----------------------------------------------------------
# HOST_PORT: host-exposed port used by docker-compose.
HOST_PORT=8000

# ----------------------------------------------------------
# 5. Data Persistence (SQLite)
# ----------------------------------------------------------
# DB_PATH: chat-history database file path.
# Docker deployments override this to /app/data/conversations.db in docker-compose.yml.
# For local development, use a relative path such as ./data/conversations.db.
DB_PATH=./data/conversations.db

# ----------------------------------------------------------
# 6. Advanced Configuration (Optional)
# ----------------------------------------------------------
# SILICONFLOW_API_KEY: optional SiliconFlow backup service key.
SILICONFLOW_API_KEY=

# NOTION_CLIENT_VERSION: Notion web client version. Update if Notion changes protocol behavior.
NOTION_CLIENT_VERSION=23.13.20260228.0625

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# NOTION_PERSIST_THREADS: Default persistence behavior for Notion AI threads.
# - true: Always persist and show threads in Notion AI chat history.
# - false: Delete ephemeral threads after streaming (default for standard/lite modes).
NOTION_PERSIST_THREADS=false

# Timezone.
TZ=UTC
